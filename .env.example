# Required
PAYLOAD_SECRET=your-secret-key-here

# SQLite - local development
DATABASE_URL=file:./my-app.db

# Production Railway (use a mounted volume path)
# DATABASE_URL=file:/data/payload.db

# Railway will auto-set PORT, but set this to your Railway domain after deploy
# NEXT_PUBLIC_SERVER_URL=https://your-app.up.railway.app
